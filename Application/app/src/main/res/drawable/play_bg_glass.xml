<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <!-- رنگ پس‌زمینه سفید با شفافیت 90% -->
    <solid android:color="#86FFFFFF" />

    <!-- حاشیه نازک سفید برای وضوح بیشتر -->
    <stroke
        android:width="1dp"
        android:color="#86ffffff" />

    <!-- سایه ملایم (در API 21+ کار می‌کند) -->
    <solid android:color="#83ffffff" />

</shape>