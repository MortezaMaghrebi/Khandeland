<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- رنگ پس‌زمینه به صورت گرادیانت ملایم -->
    <gradient
        android:startColor="#cbd5e1"
        android:endColor="#94a3b8"
        android:angle="135"
        android:type="linear" />

    <!-- گوشه‌های گرد برای هماهنگی با کارت ویدیو -->
    <corners android:radius="32dp" />

    <!-- حاشیه نازک برای زیبایی -->
    <stroke
        android:width="1dp"
        android:color="#e2e8f0" />

</shape>