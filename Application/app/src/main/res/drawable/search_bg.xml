<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- رنگ پس‌زمینه سفید مایل به خاکستری -->
    <solid android:color="#f8fafc" />

    <!-- گوشه‌های کاملاً گرد (قرص مانند) -->
    <corners android:radius="32dp" />

    <!-- حاشیه نازک خاکستری -->
    <stroke
        android:width="1dp"
        android:color="#e2e8f0" />

    <!-- فاصله داخلی -->
    <padding
        android:left="16dp"
        android:right="16dp"
        android:top="12dp"
        android:bottom="12dp" />

</shape>