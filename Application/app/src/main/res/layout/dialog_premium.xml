<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:layoutDirection="rtl"
    android:background="@drawable/dialog_bg">

    <!-- ایموجی تاج -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="👑"
        android:textSize="48sp"
        android:layout_gravity="center" />

    <TextView
        android:fontFamily="@font/yekan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="نسخه ویژه خنده لند"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#2D1B4E"
        android:layout_gravity="center"
        android:layout_marginTop="8dp" />

    <!-- قیمت -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#FFF0E0"
        android:padding="12dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:fontFamily="@font/yekan"
            android:id="@+id/tvPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="39,000 تومان"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#E67E22" />

        <TextView
            android:fontFamily="@font/yekan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" (یکبار مصرف)"
            android:textSize="12sp"
            android:textColor="#666"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- ویژگی‌ها -->
    <TextView
        android:fontFamily="@font/yekan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✅ حذف همیشگی تبلیغات"
        android:textSize="14sp"
        android:textColor="#2D1B4E"
        android:layout_marginBottom="8dp" />

    <TextView
        android:fontFamily="@font/yekan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✅ تماشای بدون وقفه کلیپ"
        android:textSize="14sp"
        android:textColor="#2D1B4E"
        android:layout_marginBottom="8dp" />

    <TextView
        android:fontFamily="@font/yekan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✅ حمایت از تولید محتوا"
        android:textSize="14sp"
        android:textColor="#2D1B4E"
        android:layout_marginBottom="20dp" />

    <!-- دکمه‌ها -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnBuy"
            android:fontFamily="@font/yekan"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="💰 خرید نسخه ویژه"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/button_premium_bg"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnCancel"
            android:fontFamily="@font/yekan"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="😐 بعداً"
            android:textColor="#eeeeee"
            android:textSize="16sp"
            android:background="@drawable/button_cancel_bg" />

    </LinearLayout>

</LinearLayout>