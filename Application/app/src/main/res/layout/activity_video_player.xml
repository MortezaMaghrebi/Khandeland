<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- هدر با طراحی مدرن -->
        <androidx.cardview.widget.CardView
            android:id="@+id/headerCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#1E1E1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_back_white"
                    android:padding="6dp"
                    android:contentDescription="بازگشت" />

                <TextView android:fontFamily="@font/yekan"
                    android:id="@+id/tvVideoTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="در حال پخش..."
                    android:textStyle="bold"/>


                <ImageView
                    android:id="@+id/btnRefresh"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_refresh"
                    android:padding="6dp"
                    android:contentDescription="بارگذاری مجدد" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- پلیر ویدیو -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_margin="8dp"
            android:layout_marginTop="0dp">

            <WebView
                android:id="@+id/webView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- ProgressBar در حال بارگذاری -->
            <LinearLayout
                android:id="@+id/loadingLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#1A1A1A"
                android:visibility="gone">

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:indeterminateTint="#E91E63" />

                <TextView android:fontFamily="@font/yekan"
                    android:id="@+id/tvLoadingText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="⏳ در حال بارگذاری ویدیو..."
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

        </FrameLayout>

        <!-- اطلاعات ویدیو -->
        <androidx.cardview.widget.CardView
            android:id="@+id/infoCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#1E1E1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- اطلاعات کانال -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_avatar_placeholder"
                        android:contentDescription="آواتار" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView android:fontFamily="@font/yekan"
                            android:id="@+id/tvUsername"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ClipChin | ورزشی"
                            android:textColor="#E91E63"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="horizontal">

                            <TextView android:fontFamily="@font/yekan"
                                android:id="@+id/tvViews"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="👁️ 0 بازدید"
                                android:textColor="#999999"
                                android:textSize="12sp" />

                            <TextView android:fontFamily="@font/yekan"
                                android:id="@+id/tvLikes"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:text="❤️ 0"
                                android:textColor="#999999"
                                android:textSize="12sp" />

                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

                <!-- خط جداکننده -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:background="#333333" />

                <!-- دکمه‌های اکشن -->
                <LinearLayout
                    android:id="@+id/actionButtonsLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <TextView android:fontFamily="@font/yekan"
                        android:id="@+id/btnDownload"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/button_action_bg"
                        android:drawableStart="@drawable/ic_aparat"
                        android:drawablePadding="8dp"
                        android:gravity="center"
                        android:text="دانلود"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp" />

                    <TextView android:fontFamily="@font/yekan"
                        android:id="@+id/btnLike"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginStart="2dp"
                        android:layout_marginEnd="2dp"
                        android:background="@drawable/button_action_bg"
                        android:drawableStart="@drawable/ic_like_outline_white"
                        android:drawablePadding="8dp"
                        android:gravity="center"
                        android:text="پسندیدن"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp" />
                    <TextView android:fontFamily="@font/yekan"
                        android:id="@+id/btnShare"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/button_action_bg"
                        android:drawableStart="@drawable/ic_share_white"
                        android:drawablePadding="8dp"
                        android:gravity="center"
                        android:text="اشتراک"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp" />


                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- بخش نظرات -->
        <androidx.cardview.widget.CardView
            android:id="@+id/commentsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#1E1E1E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView android:fontFamily="@font/yekan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💬 یادداشت های شما"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <!-- لیست نظرات -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/commentsRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:nestedScrollingEnabled="false"
                    android:visibility="visible"/>

                <TextView android:fontFamily="@font/yekan"
                    android:id="@+id/tvNoComments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="😊 هنوز یادداشتی ثبت نشده است"
                    android:textColor="#999999"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:padding="20dp"
                    android:visibility="gone"/>

                <!-- خط جداکننده -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="12dp"
                    android:background="#333333"/>

                <!-- نوشتن نظر جدید -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etNewComment"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="یادداشت شخصی خود را بنویسید..."
                        android:textColorHint="#999999"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/button_action_bg"
                        android:padding="12dp"
                        android:minHeight="40dp"
                        android:textSize="12sp"
                        android:inputType="textMultiLine"
                        android:maxLines="3"/>

                    <Button
                        android:id="@+id/btnSendComment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="ثبت"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:background="@drawable/button_action_bg"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- کانتینر برای حالت تمام صفحه -->
    <FrameLayout
        android:id="@+id/fullscreenContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="#000000" />

</FrameLayout>