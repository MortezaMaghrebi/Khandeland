<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#ffffff"
    android:layoutDirection="rtl"
    android:layout_marginBottom="12dp"
    android:layout_marginHorizontal="8dp"
    android:elevation="2dp"
    android:padding="12dp">

    <TextView
        android:fontFamily="@font/yekan"
        android:id="@+id/tvCaption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="عنوان ویدیو"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#2D1B4E"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginBottom="8dp" />

    <FrameLayout
        android:id="@+id/videoContainer"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="#000000"
        android:layout_marginBottom="8dp">

        <ImageView
            android:id="@+id/ivThumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_placeholder"
            android:visibility="visible" />

        <WebView
            android:id="@+id/webViewPlayer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"

            />

        <ImageView
            android:id="@+id/btnPlayVideo"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_play"
            android:background="@drawable/play_square_bg"
            android:padding="16dp"
            android:visibility="visible" />

        <TextView
            android:fontFamily="@font/yekan"
            android:id="@+id/tvDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="8dp"
            android:background="#80000000"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:text="0:00"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />

        <ProgressBar
            android:id="@+id/progressBarVideo"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:indeterminateTint="#FF9A3C"
            android:visibility="gone" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="4dp">

        <TextView
            android:fontFamily="@font/yekan"
            android:id="@+id/tvWatchedBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ دیده شده"
            android:textSize="10sp"
            android:textColor="#10B981"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_gravity="end">

            <ImageView
                android:id="@+id/ivLike"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_like_outline"
                android:padding="4dp" />

            <TextView
                android:fontFamily="@font/yekan"
                android:id="@+id/tvStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textSize="11sp"
                android:textColor="#64748b"
                android:layout_marginStart="4dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>